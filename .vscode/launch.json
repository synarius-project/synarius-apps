      "env": {
        "PYTHONPATH": "${workspaceFolder}/src;${workspaceFolder}/../synarius-core/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Apps / ParaWiz (Run)",
      "type": "debugpy",
      "request": "launch",
      "module": "synarius_parawiz",
      "noDebug": true,
