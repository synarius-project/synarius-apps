      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src;${workspaceFolder}/../synarius-core/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "stopOnEntry": false
    },
    {
      "name": "Apps / ParaWiz (Debug)",
      "type": "debugpy",
      "request": "launch",
      "module": "synarius_parawiz",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
